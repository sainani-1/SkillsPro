# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_ADMIN_RESET_PASSWORD_ENDPOINT=https://your-project-ref.supabase.co/functions/v1/admin-reset-password
VITE_PUBLIC_APP_URL=https://your-domain.com
VITE_AI_BASE_URL=http://127.0.0.1:11434
VITE_AI_MODEL=llama3:latest
VITE_AI_MAX_HISTORY_MESSAGES=4
VITE_AI_MAX_TOKENS=220
VITE_AI_TEMPERATURE=0.2
VITE_AI_TOP_P=0.85
VITE_AI_TIMEOUT_MS=20000
VITE_JUDGE0_URL=https://your-judge0-instance.example.com
VITE_JUDGE0_API_KEY=
VITE_JUDGE0_API_HOST=
VITE_ONECOMPILER_API_KEY=
VITE_ONECOMPILER_API_HOST=onecompiler-apis.p.rapidapi.com
VITE_LOGIN_OTP_ENDPOINT=/api/login-otp

# Login email OTP sender. Use a Gmail app password, not your normal Gmail password.
SMTP_EMAIL=your_gmail_address@gmail.com
SMTP_APP_PASSWORD=your_16_character_google_app_password
SMTP_PORT=587
OTP_FROM_NAME=SkillPro
LOGIN_OTP_SECRET=change_this_to_a_long_random_secret

# Razorpay Configuration
# Get your API keys from: https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
VITE_RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Note: Keep VITE_RAZORPAY_KEY_SECRET secure and never expose it in frontend
# Use it only for backend/server-side operations
